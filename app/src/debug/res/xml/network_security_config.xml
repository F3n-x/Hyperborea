<?xml version="1.0" encoding="utf-8"?>
<network-security-config xmlns:tools="http://schemas.android.com/tools">
    <!-- Debug builds only: allow cleartext to a local dev server. The release config
         (app/src/main/res/xml/network_security_config.xml) disallows cleartext everywhere. -->
    <base-config cleartextTrafficPermitted="true" tools:ignore="InsecureBaseConfiguration" />
</network-security-config>
